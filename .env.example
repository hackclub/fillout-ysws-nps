# Copy to .env and fill in. .env is gitignored.
OPENAI_API_KEY=sk-...
FILLOUT_API_KEY=sk_...

# Airtable — the base/table NPS records are written to. Use a SCRATCH base in
# dev; the NPS table is referenced by name so it is portable to production.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# Table name on the base (default "NPS").
NPS_TABLE=NPS
# How often each active sync job polls Fillout (Go duration, default 30s).
NPS_POLL_INTERVAL=30s

# Comma-separated login allow-list (always-available bootstrap admins). Login is
# ALSO granted to any email in the "Hack Club Auth Email" field of the "YSWS
# Authors" table in AIRTABLE_BASE_ID, so most users need not be listed here.
ALLOWED_EMAILS=you@hackclub.com
# Random secret used to sign session cookies. Generate with:
#   head -c 32 /dev/urandom | base64
SESSION_SECRET=

# Hack Club OAuth (auth.hackclub.com) — credentials for your registered app.
HC_AUTH_CLIENT_ID=
HC_AUTH_CLIENT_SECRET=
# Base URL of this app; the registered callback is <base>/callback
# (e.g. http://localhost:3000 -> http://localhost:3000/callback). The app's
# host port (APP_PORT below) must match this URL so the OAuth callback resolves.
HC_AUTH_CALLBACK_BASE_URL=http://localhost:3000

# ── Docker dev environment ───────────────────────────────────────────────
# Running several dev environments on one machine? Give each a unique
# COMPOSE_PROJECT_NAME and unique host ports so their containers, networks,
# volumes, and published ports never collide.

# Compose prefixes every container/network/volume with this name.
COMPOSE_PROJECT_NAME=fillout-ysws-nps

# Host ports. The app container always listens on 8080 and Postgres on 5432
# internally; these only control what gets published to your machine.
APP_PORT=8080
POSTGRES_PORT=5432

# Postgres credentials (init the db container; reachable from the app at db:5432).
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
